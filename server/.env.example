# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
# Formats: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Authentication
JWT_SECRET=generate_a_long_random_string_here

# OpenAI Integration
OPENAI_API_KEY=sk-proj-xxx

# Stripe Integration
STRIPE_SECRET_KEY=sk_test_xxx

# Meta / Marketing API
META_APP_ID=xxx
META_APP_SECRET=xxx
META_WEBHOOK_SECRET=xxx
META_VERIFY_TOKEN=xxx

# WhatsApp (Meta)
WHATSAPP_VERSION=v17.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# WhatsApp (Gallabox)
GALLABOX_WEBHOOK_SECRET=

# Redis Configuration

# Security
SESSION_SECRET=xxx
CSRF_SECRET=xxx

# CORS / Frontend
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth (Gmail Integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/settings/gmail-callback
